{
  "name": "genpark-semrush-aio-toolkit-skill",
  "version": "1.0.0",
  "description": "GenPark AI Agent Skill - Optimize keywords and semantic layouts to adapt pages for AI Overviews (AIO).",
  "author": "genpark",
  "category": "marketing",
  "tags": [
    "semrush",
    "aio",
    "keywords",
    "seo",
    "overviews"
  ],
  "inputs": {
